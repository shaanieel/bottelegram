# =========================================================
# ZAEIN Automation Bot - Environment Variables (SECRETS)
# =========================================================
# Copy this file to ".env" and fill in real values.
# NEVER commit the real .env to git.

# Telegram Bot Token from @BotFather
TELEGRAM_BOT_TOKEN=

# Comma-separated Telegram numeric user IDs allowed to use the bot
# Get yours from @userinfobot
ADMIN_TELEGRAM_ID=

# Bunny Stream API key (Library -> API tab)
BUNNY_API_KEY=

# ----- Google Drive API (OPTIONAL, recommended) -----
# Engine pertama untuk semua link Google Drive. Kalau salah satu di-set, bot
# akan pakai Google Drive API resmi (lebih stabil & quota lebih tinggi)
# sebelum fallback ke gdown / direct uc-download.
# Prioritas auth: OAuth token > Service Account > API Key.

# Mode A (TERBAIK untuk file private Anda sendiri): OAuth user token.
# Login ke akun Google Anda sekali; bot pakai identitas Anda untuk semua
# request. Bisa baca SEMUA file private yang Anda punya (sama seperti
# Pikabot / mirror-leech-telegram-bot).
# Cara setup:
#   1. Buat OAuth Client ID (type: Desktop app) di Cloud Console:
#      https://console.cloud.google.com/apis/credentials
#   2. Download JSON, simpan ke "secrets/credentials.json".
#   3. Jalankan: python tools/generate_drive_token.py
#      Browser akan buka, login Google, klik Allow.
#   4. Set path token (default: secrets/token.pickle) di bawah.
GOOGLE_DRIVE_OAUTH_TOKEN_PATH=

# Mode B: Service Account — public + private (file/folder/Shared Drive yang
# di-share ke email service account). Isi dengan PATH ke file JSON key
# (contoh: "secrets/sa-drive.json").
GOOGLE_DRIVE_SERVICE_ACCOUNT_JSON=

# Mode C: API Key — public files only ("Anyone with the link"). Tidak bisa
# baca file private (limitation Google, bukan bot). Buat di:
# https://console.cloud.google.com/apis/credentials
# (enable "Google Drive API" pada project lalu generate API key).
GOOGLE_DRIVE_API_KEY=

# ----- Player4Me API token (OPTIONAL) -----
# Untuk command /m, /upload_player4me, dan tombol "Player4Me" di /m.
# Dapatkan token di dashboard player4me: https://player4me.com/  -> menu API.
# Header otentikasi yang dipakai: "api-token: <token>".
PLAYER4ME_API_TOKEN=

# ----- Telegram Index login (OPTIONAL) -----
# Untuk command /gdrive_list dan /mirror_gdrive saat halaman index
# (mis. https://zindex.aioarea.us.kg/...) butuh login. Bot akan
# otomatis POST ke /login dan cache cookie session-nya, plus re-login
# otomatis kalau session expire.
TGINDEX_USERNAME=
TGINDEX_PASSWORD=
