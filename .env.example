# =========================================================
# ZAEIN Automation Bot - Environment Variables (SECRETS)
# =========================================================
# Copy this file to ".env" and fill in real values.
# NEVER commit the real .env to git.

# Telegram Bot Token from @BotFather
TELEGRAM_BOT_TOKEN=

# Comma-separated Telegram numeric user IDs allowed to use the bot
# Get yours from @userinfobot
ADMIN_TELEGRAM_ID=

# Bunny Stream API key (Library -> API tab)
BUNNY_API_KEY=

# ----- Google Drive API (OPTIONAL, recommended) -----
# Engine pertama untuk semua link Google Drive. Kalau salah satu di-set, bot
# akan pakai Google Drive API resmi (lebih stabil & quota lebih tinggi)
# sebelum fallback ke gdown / yt-dlp.

# Mode A: API Key — public files only.
# Buat di https://console.cloud.google.com/apis/credentials
# (enable "Google Drive API" pada project lalu generate API key).
GOOGLE_DRIVE_API_KEY=

# Mode B: Service Account — public + private (file/folder/Shared Drive yang
# di-share ke email service account). Isi dengan PATH ke file JSON key
# (contoh: "secrets/sa-drive.json"). Membutuhkan paket "google-auth"
# (sudah ada di requirements.txt).
GOOGLE_DRIVE_SERVICE_ACCOUNT_JSON=

# ----- Player4Me API token (OPTIONAL) -----
# Untuk command /m, /upload_player4me, dan tombol "Player4Me" di /m.
# Dapatkan token di dashboard player4me: https://player4me.com/  -> menu API.
# Header otentikasi yang dipakai: "api-token: <token>".
PLAYER4ME_API_TOKEN=
